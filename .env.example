# server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development
DATA_DIR=./data

# quotes + verification
QUOTE_EXPIRY_SECONDS=120
BTC_QUOTE_EXPIRY_SECONDS=120
MIN_CONFIRMATIONS=1

# webhook delivery
WEBHOOK_SECRET=dev_webhook_secret_change_me
WEBHOOK_TIMEOUT_MS=3000
WEBHOOK_RETRIES=3
WEBHOOK_BACKOFF_MS=1000

# dashboard auth
DASHBOARD_TOKEN=change_me_before_public_deploy

# manual payment engine
MANUAL_PAYMENT_MNEMONIC=
MANUAL_PAYMENT_DERIVATION_PATH=m/44'/60'/0'/0
MANUAL_PAYMENT_SWEEP_SPONSOR_PRIVATE_KEY=
MANUAL_PAYMENT_SCAN_INTERVAL_MS=15000
MANUAL_PAYMENT_SCAN_BLOCK_WINDOW=250

# evm rpc endpoints
RPC_ETHEREUM=
RPC_BASE=
RPC_ARBITRUM=
RPC_POLYGON=

# bitcoin indexing
BTC_ESPLORA_BASE_URL=https://blockstream.info/api
