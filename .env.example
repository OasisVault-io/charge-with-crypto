# server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development
APP_MODE=demo
DATA_DIR=./data

# quotes + verification
QUOTE_EXPIRY_SECONDS=120
BTC_QUOTE_EXPIRY_SECONDS=120
MIN_CONFIRMATIONS=1

# webhook delivery
WEBHOOK_SECRET=dev_webhook_secret_change_me
WEBHOOK_TIMEOUT_MS=3000
WEBHOOK_RETRIES=3
WEBHOOK_BACKOFF_MS=1000

# dashboard auth
# required when APP_MODE=production
DASHBOARD_TOKEN=change_me_before_public_deploy

# x402 agent payments on Base USDC
X402_ENABLED=false
X402_FACILITATOR_URL=
X402_BASE_NETWORK=eip155:8453
X402_BASE_ASSET=USDC
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# manual payment engine
# prefer MANUAL_PAYMENT_XPUB for EVM deposit derivation; mnemonic is only needed for legacy in-app sweeping
MANUAL_PAYMENT_XPUB=
MANUAL_PAYMENT_MNEMONIC=
MANUAL_PAYMENT_DERIVATION_PATH=m/44'/60'/0'/0
MANUAL_PAYMENT_ALLOWED_CHAINS=base,ethereum
MANUAL_PAYMENT_START_INDEX=0
MANUAL_PAYMENT_SWEEP_SIGNER_URL=
MANUAL_PAYMENT_SWEEP_SIGNER_SECRET=
MANUAL_PAYMENT_SWEEP_SPONSOR_PRIVATE_KEY=
MANUAL_PAYMENT_SCAN_INTERVAL_MS=15000
MANUAL_PAYMENT_SCAN_BLOCK_WINDOW=250

# evm rpc endpoints
RPC_ETHEREUM=
RPC_BASE=
RPC_ARBITRUM=
RPC_POLYGON=

# bitcoin indexing
BTC_ESPLORA_BASE_URL=https://blockstream.info/api
