{
  "name": "charge-with-crypto",
  "version": "1.0.0",
  "private": true,
  "description": "Open source wallet-first crypto checkout demo",
  "scripts": {
    "build:wallet-vendors": "node --import tsx scripts/build-wallet-vendors.ts",
    "build": "npm run build:wallet-vendors && react-router build --config vite.react-router.config.ts",
    "build:rr7": "react-router build --config vite.react-router.config.ts",
    "dev:rr7": "react-router dev --config vite.react-router.config.ts",
    "dev": "react-router dev --config vite.react-router.config.ts",
    "manual:sweep": "node --import tsx scripts/manual-sweep.ts",
    "routes:rr7": "react-router routes --config vite.react-router.config.ts",
    "start": "react-router-serve ./build/server/index.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.rr7.json --noEmit",
    "typecheck:rr7": "tsc -p tsconfig.rr7.json --noEmit"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@epic-web/config": "^1.24.1",
    "@phantom/browser-sdk": "^1.0.5",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/extensions": "^2.6.0",
    "better-sqlite3": "^12.8.0",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "drizzle-orm": "^0.45.1",
    "isbot": "^5",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "sats-connect": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "tiny-secp256k1": "^2.2.4",
    "viem": "^2.47.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
