{
  "name": "charge-with-crypto",
  "version": "1.0.0",
  "private": true,
  "description": "Open source wallet-first crypto checkout demo",
  "scripts": {
    "build:wallet-vendors": "node --import tsx scripts/build-wallet-vendors.ts",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:wallet-vendors && npm run build:client && npm run build:server",
    "dev:server": "NODE_ENV=development node --watch --import tsx src/server.ts",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev": "concurrently -k -n server,client -c cyan,yellow \"npm:dev:server\" \"npm:dev:client\"",
    "start": "node dist/server/src/server.js",
    "start:source": "node --import tsx src/server.ts",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@phantom/browser-sdk": "^1.0.5",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "ethers": "^6.16.0",
    "qrcode": "^1.5.4",
    "sats-connect": "^4.2.1",
    "tiny-secp256k1": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
